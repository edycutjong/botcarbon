    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "topojson-client": "^3.1.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
